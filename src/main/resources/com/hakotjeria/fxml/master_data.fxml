<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hakotjeria.controller.MasterDataController" spacing="18"
      stylesheets="@../css/app.css">
    <padding>
        <Insets top="28" right="30" bottom="28" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4">
            <Label text="Master Data" styleClass="page-title"/>
            <Label text="Kelola inventaris bahan baku mentah dan produk jadi siap jual."
                   styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newItemButton" text="+  Tambah Data Baru" styleClass="btn-primary"
                onAction="#onTambahData"/>
    </HBox>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Bahan Baku (Raw Materials)">
            <VBox styleClass="card" spacing="12">
                <HBox styleClass="toolbar">
                    <TextField fx:id="searchBahanField" promptText="Cari bahan baku..."
                               styleClass="form-field" prefWidth="300"/>
                </HBox>
                <TableView fx:id="bahanTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBahanNama" text="NAMA BAHAN" prefWidth="240"/>
                        <TableColumn fx:id="colBahanSatuan" text="SATUAN" prefWidth="90"/>
                        <TableColumn fx:id="colBahanBatas" text="BATAS MIN. AMAN" prefWidth="140"/>
                        <TableColumn fx:id="colBahanStok" text="STOK SAAT INI" prefWidth="140"/>
                        <TableColumn fx:id="colBahanStatus" text="STATUS" prefWidth="110"/>
                        <TableColumn fx:id="colBahanAksi" text="AKSI" prefWidth="110"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="Produk Jadi (Finished Products)">
            <VBox styleClass="card" spacing="12">
                <HBox styleClass="toolbar">
                    <TextField fx:id="searchProdukField" promptText="Cari produk jadi..."
                               styleClass="form-field" prefWidth="300"/>
                </HBox>
                <TableView fx:id="produkTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colProdukNama" text="NAMA PRODUK" prefWidth="220"/>
                        <TableColumn fx:id="colProdukSumber" text="SUMBER" prefWidth="110"/>
                        <TableColumn fx:id="colProdukSatuan" text="SATUAN" prefWidth="90"/>
                        <TableColumn fx:id="colProdukBatas" text="BATAS MIN. AMAN" prefWidth="130"/>
                        <TableColumn fx:id="colProdukStok" text="STOK SAAT INI" prefWidth="130"/>
                        <TableColumn fx:id="colProdukStatus" text="STATUS" prefWidth="100"/>
                        <TableColumn fx:id="colProdukAksi" text="AKSI" prefWidth="110"/>
                    </columns>
                </TableView>
                <HBox styleClass="info-banner" spacing="8" alignment="CENTER_LEFT">
                    <Label text="Kelola BOM (Bill of Materials): buka menu Formulasi BOM untuk mengatur resep bahan baku produk Internal."
                           wrapText="true" styleClass="label-muted"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
