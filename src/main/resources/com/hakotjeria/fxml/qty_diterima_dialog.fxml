<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hakotjeria.controller.QtyDiterimaDialogController"
      spacing="12" prefWidth="460" styleClass="login-background"
      stylesheets="@../css/app.css">
    <padding>
        <Insets top="24" right="26" bottom="24" left="26"/>
    </padding>

    <Label text="Konfirmasi Pengambilan Eksternal" styleClass="section-title"/>
    <Label fx:id="infoLabel" wrapText="true" styleClass="page-subtitle"
           text="Barang diterima dalam wujud jadi dari Kedai Tjeria. Resep BOM diabaikan sepenuhnya."/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <VBox.margin>
            <Insets top="6"/>
        </VBox.margin>
        <Label text="Qty Diterima:" styleClass="form-label"/>
        <TextField fx:id="qtyDiterimaField" styleClass="form-field" prefWidth="140"/>
        <Label fx:id="satuanLabel" text="" styleClass="label-muted"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="targetLabel" text="" styleClass="label-muted"/>
    </HBox>

    <HBox styleClass="info-banner">
        <Label text="Perubahan status menjadi &quot;Sudah Diambil&quot; bersifat satu arah dan tugas akan terkunci (R07.4)."
               wrapText="true" styleClass="label-muted"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <VBox.margin>
            <Insets top="6"/>
        </VBox.margin>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Batal" styleClass="btn-secondary" onAction="#onBatal"/>
        <Button fx:id="konfirmasiButton" text="Konfirmasi Penerimaan" styleClass="btn-primary"
                defaultButton="true" onAction="#onKonfirmasi"/>
    </HBox>
</VBox>
