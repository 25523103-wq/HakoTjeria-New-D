<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hakotjeria.controller.RiwayatMutasiController" spacing="18">
    <padding>
        <Insets top="28" right="30" bottom="28" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4">
            <Label text="Riwayat Mutasi Stok" styleClass="page-title-primary"/>
            <Label text="Pantau setiap perubahan stok bahan baku dan produk jadi."
                   styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="catatMutasiButton" text="Catat Mutasi Manual" styleClass="btn-secondary"
                onAction="#onCatatMutasi"/>
        <Button fx:id="exportButton" text="Export PDF" styleClass="btn-primary" onAction="#onExportPdf"/>
    </HBox>

    <HBox styleClass="toolbar">
        <FlowPane hgap="12" vgap="10">
            <VBox spacing="4">
                <Label text="Nama Barang" styleClass="form-label"/>
                <ComboBox fx:id="barangCombo" styleClass="form-field" prefWidth="220"
                          promptText="Semua barang"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Jenis Mutasi" styleClass="form-label"/>
                <ComboBox fx:id="jenisCombo" styleClass="form-field" prefWidth="140"
                          promptText="Semua"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Shift" styleClass="form-label"/>
                <ComboBox fx:id="shiftCombo" styleClass="form-field" prefWidth="140"
                          promptText="Semua"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Dari Tanggal" styleClass="form-label"/>
                <DatePicker fx:id="dariPicker" styleClass="form-field" prefWidth="160"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Sampai Tanggal" styleClass="form-label"/>
                <DatePicker fx:id="sampaiPicker" styleClass="form-field" prefWidth="160"/>
            </VBox>
            <VBox spacing="4">
                <Label text=" " styleClass="form-label"/>
                <HBox spacing="8">
                    <Button text="Filter" styleClass="btn-primary" onAction="#onFilter"/>
                    <Button text="Reset" styleClass="btn-secondary" onAction="#onReset"/>
                </HBox>
            </VBox>
        </FlowPane>
    </HBox>

    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Mutasi Bahan Baku">
            <VBox styleClass="card" spacing="12">
                <TableView fx:id="bahanTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBbTanggal" text="TANGGAL" prefWidth="110"/>
                        <TableColumn fx:id="colBbShift" text="SHIFT" prefWidth="80"/>
                        <TableColumn fx:id="colBbNama" text="NAMA BAHAN" prefWidth="200"/>
                        <TableColumn fx:id="colBbJenis" text="JENIS" prefWidth="80"/>
                        <TableColumn fx:id="colBbQty" text="QTY" prefWidth="130"/>
                        <TableColumn fx:id="colBbKet" text="KETERANGAN" prefWidth="230"/>
                        <TableColumn fx:id="colBbUser" text="PENGINPUT" prefWidth="140"/>
                    </columns>
                </TableView>
                <HBox fx:id="ringkasanBahanBox" spacing="18" styleClass="info-banner" alignment="CENTER_LEFT"/>
            </VBox>
        </Tab>
        <Tab text="Mutasi Produk Jadi">
            <VBox styleClass="card" spacing="12">
                <TableView fx:id="produkTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPjTanggal" text="TANGGAL" prefWidth="110"/>
                        <TableColumn fx:id="colPjShift" text="SHIFT" prefWidth="80"/>
                        <TableColumn fx:id="colPjNama" text="NAMA PRODUK" prefWidth="200"/>
                        <TableColumn fx:id="colPjJenis" text="JENIS" prefWidth="80"/>
                        <TableColumn fx:id="colPjQty" text="QTY" prefWidth="130"/>
                        <TableColumn fx:id="colPjKet" text="KETERANGAN" prefWidth="230"/>
                        <TableColumn fx:id="colPjUser" text="PENGINPUT" prefWidth="140"/>
                    </columns>
                </TableView>
                <HBox fx:id="ringkasanProdukBox" spacing="18" styleClass="info-banner" alignment="CENTER_LEFT"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
