<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hakotjeria.controller.StockOpnameController" spacing="18"
      stylesheets="@../css/app.css">
    <padding>
        <Insets top="28" right="30" bottom="28" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4">
            <Label text="Stock Opname" styleClass="page-title-primary"/>
            <Label text="Input stok fisik akhir shift dan kirim ajuan penyesuaian stok."
                   styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusChipHolder" text=""/>
    </HBox>

    <HBox styleClass="toolbar" spacing="12" alignment="CENTER_LEFT">
        <Label text="Tanggal:" styleClass="form-label"/>
        <DatePicker fx:id="tanggalPicker" styleClass="form-field" prefWidth="170"/>
        <Label text="Shift:" styleClass="form-label"/>
        <ComboBox fx:id="shiftCombo" styleClass="form-field" prefWidth="150"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="muatButton" text="Muat Dokumen" styleClass="btn-secondary" onAction="#onMuat"/>
    </HBox>

    <HBox fx:id="infoBox" styleClass="info-banner" visible="false" managed="false">
        <Label fx:id="infoLabel" wrapText="true" styleClass="label-muted"/>
    </HBox>

    <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <TextField fx:id="cariField" promptText="Cari barang..." styleClass="form-field" prefWidth="280"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="totalSelisihLabel" text="" styleClass="label-strong"/>
        </HBox>

        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <Tab text="Bahan Baku">
                <TableView fx:id="bahanTable" styleClass="table-view" editable="true" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBbNama" text="NAMA BAHAN BAKU" prefWidth="240"/>
                        <TableColumn fx:id="colBbSatuan" text="SATUAN" prefWidth="90"/>
                        <TableColumn fx:id="colBbSistem" text="STOK SISTEM" prefWidth="140"/>
                        <TableColumn fx:id="colBbFisik" text="STOK FISIK" prefWidth="150"/>
                        <TableColumn fx:id="colBbSelisih" text="SELISIH" prefWidth="130"/>
                    </columns>
                </TableView>
            </Tab>
            <Tab text="Produk Jadi">
                <TableView fx:id="produkTable" styleClass="table-view" editable="true" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPjNama" text="NAMA PRODUK JADI" prefWidth="240"/>
                        <TableColumn fx:id="colPjSatuan" text="SATUAN" prefWidth="90"/>
                        <TableColumn fx:id="colPjSistem" text="STOK SISTEM" prefWidth="140"/>
                        <TableColumn fx:id="colPjFisik" text="STOK FISIK" prefWidth="150"/>
                        <TableColumn fx:id="colPjSelisih" text="SELISIH" prefWidth="130"/>
                    </columns>
                </TableView>
            </Tab>
        </TabPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="simpanDraftButton" text="Simpan Draft" styleClass="btn-secondary"
                    onAction="#onSimpanDraft"/>
            <Button fx:id="kirimButton" text="Kirim ke Supervisor" styleClass="btn-primary"
                    onAction="#onKirimAjuan"/>
            <Button fx:id="setujuiButton" text="Setujui" styleClass="btn-success"
                    onAction="#onSetujui" visible="false" managed="false"/>
            <Button fx:id="tolakButton" text="Tolak" styleClass="btn-danger"
                    onAction="#onTolak" visible="false" managed="false"/>
        </HBox>
    </VBox>
</VBox>
