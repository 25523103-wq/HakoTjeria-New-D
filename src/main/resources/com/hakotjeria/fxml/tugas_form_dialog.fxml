<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hakotjeria.controller.TugasFormDialogController"
      spacing="14" prefWidth="520" styleClass="login-background">
    <padding>
        <Insets top="24" right="26" bottom="24" left="26"/>
    </padding>

    <Label fx:id="judulLabel" text="Tambah Tugas Operasional" styleClass="section-title"/>

    <GridPane hgap="14" vgap="12">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="Tanggal" styleClass="form-label"/>
            <DatePicker fx:id="tanggalPicker" styleClass="form-field" maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="Shift" styleClass="form-label"/>
            <ComboBox fx:id="shiftCombo" styleClass="form-field" maxWidth="Infinity"
                      promptText="Pilih shift"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label text="Kategori Tugas" styleClass="form-label"/>
            <ComboBox fx:id="kategoriCombo" styleClass="form-field" maxWidth="Infinity"
                      promptText="Pilih kategori"/>
        </VBox>
        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label text="Produk Jadi Target" styleClass="form-label"/>
            <ComboBox fx:id="produkCombo" styleClass="form-field" maxWidth="Infinity"
                      promptText="Pilih produk"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <Label text="Qty Target" styleClass="form-label"/>
            <TextField fx:id="qtyTargetField" styleClass="form-field" promptText="Contoh: 10"/>
        </VBox>
        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <Label text="Staff Penanggung Jawab" styleClass="form-label"/>
            <ComboBox fx:id="staffCombo" styleClass="form-field" maxWidth="Infinity"
                      promptText="Pilih staff"/>
        </VBox>
    </GridPane>

    <VBox spacing="6">
        <Label text="Catatan (opsional)" styleClass="form-label"/>
        <TextField fx:id="catatanField" styleClass="form-field" promptText="Catatan tambahan..."/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <VBox.margin>
            <Insets top="6"/>
        </VBox.margin>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Batal" styleClass="btn-secondary" onAction="#onBatal"/>
        <Button fx:id="simpanButton" text="Simpan Tugas" styleClass="btn-primary"
                defaultButton="true" onAction="#onSimpan"/>
    </HBox>
</VBox>
